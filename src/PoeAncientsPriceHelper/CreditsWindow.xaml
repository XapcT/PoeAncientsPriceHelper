<Window x:Class="PoeAncientsPriceHelper.CreditsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contributors" Height="400" Width="340"
        Icon="app.ico"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Window.Resources>
        <!-- A flat clickable link: underlined, hand cursor, dims on hover. Used for every GitHub
             handle and the maintainer credit. Tag carries the URL the click handler opens. -->
        <Style x:Key="LinkText" TargetType="TextBlock">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#9CC4FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Contributors"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <!-- One link per contributor, filled in from code-behind. -->
        <StackPanel Grid.Row="1" x:Name="ContributorList" Orientation="Vertical"/>

        <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Top" Margin="0,18,0,0">
            <!-- Data-source credit: the Island Rumour ratings come from a community spreadsheet. -->
            <TextBlock Text="Data sources" Foreground="#AAA" FontSize="12" FontWeight="SemiBold"/>
            <TextBlock Margin="0,2,0,0" Foreground="#CFCFCF" FontSize="12" TextWrapping="Wrap"
                       Text="Island Rumour ratings come from the community 'Expedition Cheatsheet' spreadsheet:"/>
            <TextBlock x:Name="SheetLink" Style="{StaticResource LinkText}" FontSize="13" Margin="0,3,0,0"
                       Text="Expedition Cheatsheet (Google Sheets)"
                       Tag="https://docs.google.com/spreadsheets/d/16YU8mSS7TdLPdmOunVjiPn_NrKVGfcnMkuMQDy8jgZA/htmlview"
                       MouseLeftButtonUp="Link_Click"/>

            <!-- Donor thank-you. Donations come through PayPal anonymously, so this is a general note
                 rather than a named list. -->
            <TextBlock Margin="0,16,0,0" TextWrapping="Wrap"
                       Foreground="#CFCFCF" FontSize="12"
                       Text="💛 And a heartfelt thank-you to everyone who has chipped in a donation — it keeps the app free, ad-free, and worth maintaining."/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Thanks for your contributions!"
                   Foreground="#AAA" FontSize="12" Margin="0,16,0,0"/>

        <TextBlock Grid.Row="4" x:Name="MaintainerLink"
                   Style="{StaticResource LinkText}"
                   FontSize="11" Foreground="#888"
                   Margin="0,8,0,0"
                   Text="Created by pedro-quiterio"
                   Tag="https://github.com/pedro-quiterio"
                   MouseLeftButtonUp="Link_Click"/>
    </Grid>
</Window>
