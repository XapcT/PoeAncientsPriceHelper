<Window x:Class="PoeAncientsPriceHelper.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="680" Width="380"
        Icon="app.ico"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>

        <!-- Same flat button used on the main window: a TemplateBinding template so local
             Background/Foreground/BorderBrush always apply (WPF UI's implicit style ignores them). -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.68"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Настройки" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Старт/стоп:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="HotkeyLabel" Text="F5" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" MinWidth="46"/>
            <Button x:Name="RebindButton" Content="Сменить" Style="{StaticResource FlatButton}"
                    Background="#2A2A2A" Foreground="#CCC" BorderBrush="#444"
                    FontSize="11" Padding="10,2" Click="RebindButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Диагностика:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="DebugHotkeyLabel" Text="F3" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" MinWidth="46"/>
            <Button x:Name="RebindDebugButton" Content="Сменить" Style="{StaticResource FlatButton}"
                    Background="#2A2A2A" Foreground="#CCC" BorderBrush="#444"
                    FontSize="11" Padding="10,2" Click="RebindDebugButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Калибровка:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="CalibrateHotkeyLabel" Text="F4" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" MinWidth="46"/>
            <Button x:Name="RebindCalibrateButton" Content="Сменить" Style="{StaticResource FlatButton}"
                    Background="#2A2A2A" Foreground="#CCC" BorderBrush="#444"
                    FontSize="11" Padding="10,2" Click="RebindCalibrateButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Тема:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="ThemeBox" Margin="0,4" MinWidth="120"
                  HorizontalAlignment="Left" SelectionChanged="ThemeBox_SelectionChanged"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Захват:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Vertical" Margin="0,4">
            <ComboBox x:Name="CaptureBox" MinWidth="160" HorizontalAlignment="Left"
                      SelectionChanged="CaptureBox_SelectionChanged"/>
            <TextBlock Text="(после следующего старта)" Foreground="#666" FontSize="10" Margin="0,2,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Язык игры:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Vertical" Margin="0,4">
            <ComboBox x:Name="LanguageBox" MinWidth="160" HorizontalAlignment="Left"
                      SelectionChanged="LanguageBox_SelectionChanged"/>
            <TextBlock Text="Выбери язык клиента PoE 2, чтобы названия предметов находились в ценах. (после следующего старта)"
                       Foreground="#666" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" x:Name="AutoStartBox"
                  Margin="0,12,0,0" Foreground="#CCC" FontSize="12"
                  Content="Сканировать при запуске и сворачивать в трей"
                  Checked="AutoStartBox_Changed" Unchecked="AutoStartBox_Changed"/>
        <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Top"
                   Text="Работает после калибровки области. Просто открой приложение - оно запустится в трее."
                   Foreground="#666" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>

        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,14,0,0">
            <CheckBox x:Name="RumourEnabledBox" Foreground="#CCC" FontSize="12"
                      Content="Помощник слухов (экспериментально)"
                      Checked="RumourEnabledBox_Changed" Unchecked="RumourEnabledBox_Changed"/>
            <TextBlock Foreground="#888" FontSize="10" TextWrapping="Wrap" Margin="0,3,0,0"
                       Text="Экспериментально: находит панель слухов Атласа и показывает рейтинги из таблицы сообщества. OCR может ошибаться, а часть слухов может отсутствовать."/>
        </StackPanel>

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Частота слухов:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Vertical" Margin="0,4">
            <ComboBox x:Name="RumourIntervalBox" MinWidth="160" HorizontalAlignment="Left"
                      SelectionChanged="RumourIntervalBox_SelectionChanged"/>
            <TextBlock Text="Сканирует только при открытой мировой карте." Foreground="#666" FontSize="10" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,12,0,0">
            <Button x:Name="RefreshRumoursButton" Content="Обновить данные слухов из таблицы"
                    Style="{StaticResource FlatButton}" Background="#2A2A2A" Foreground="#CCC" BorderBrush="#444"
                    FontSize="11" HorizontalAlignment="Left" Padding="10,4" Click="RefreshRumoursButton_Click"/>
            <Button x:Name="RumourSourceButton" Content="Открыть таблицу данных сообщества"
                    Style="{StaticResource FlatButton}" Background="#2A2A2A" Foreground="#CCC" BorderBrush="#444"
                    FontSize="11" HorizontalAlignment="Left" Padding="10,4" Margin="0,6,0,0" Click="RumourSourceButton_Click"/>
            <TextBlock x:Name="RumourRefreshStatus" Text="" Foreground="#888" FontSize="10"
                       Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
